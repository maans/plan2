Geometry":null},"relations":{"layoutRole":"warning"},"createdAt":"2026-07-07T13:55:00.000Z","updatedAt":"2026-07-07T13:55:00.000Z","legacy":null},{"id":"widget_udtalelser_018_video-kom-godt-i-gang-med-skriv","schemaVersion":1,"widgetVersion":1,"boardId":"board_udtalelser_05_hjaelp-til-skriv","type":"video","title":"Video · Kom godt i gang med Skriv","geometry":{"x":20,"y":85,"width":760,"height":470,"rotation":0,"z":1},"content":{"url":"https://youtu.be/zLniGIGnhg4?si=MVkgXlHrcqfgfAL-","src":"https://youtu.be/zLniGIGnhg4?si=MVkgXlHrcqfgfAL-","label":"Kom godt i gang med Skriv","fit":"contain","currentTime":0,"volume":1},"settings":{"locked":false,"hidden":false,"minimized":false,"maximized":false,"restoreGeometry":null},"relations":{"layoutRole":"video-help"},"createdAt":"2026-07-07T13:55:00.000Z","updatedAt":"2026-07-07T13:55:00.000Z","legacy":null},{"id":"widget_udtalelser_019_skriv-hjaelp-i-kort-form","schemaVersion":1,"widgetVersion":1,"boardId":"board_udtalelser_05_hjaelp-til-skriv","type":"text","title":"Skriv-hjælp i kort form","geometry":{"x":810,"y":85,"width":350,"height":300,"rotation":0,"z":2},"content":{"text":"Brug Skriv som skrivebord for udtalelsen.\n\n• Skriv én udtalelse ad gangen.\n• Brug noterne fra Plan som forberedelse.\n• Gem undervejs.\n• Lav PDF, når teksten er færdig.\n• Tilføj den færdige PDF på tavlen, hvis den skal gemmes sammen med forløbet.","fontSize":18,"align":"left"},"settings":{"locked":false,"hidden":false,"minimized":false,"maximized":false,"restoreGeometry":null},"relations":{"layoutRole":"help"},"createdAt":"2026-07-07T13:55:00.000Z","updatedAt":"2026-07-07T13:55:00.000Z","legacy":null},{"id":"widget_udtalelser_020_plan-eller-browser","schemaVersion":1,"widgetVersion":1,"boardId":"board_udtalelser_05_hjaelp-til-skriv","type":"text","title":"Plan eller browser?","geometry":{"x":810,"y":425,"width":350,"height":210,"rotation":0,"z":3},"content":{"text":"Skriv i Plan-widgetten, når arbejdet skal følge denne lokale Plan-kopi.\n\nÅ