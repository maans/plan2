    {
      "id": "widget_kontaktgruppe_001_kontaktgruppe-saadan-kommer-du-i-gang",
      "schemaVersion": 1,
      "widgetVersion": 1,
      "boardId": "board_kontaktgruppe_01_overblik",
      "type": "text",
      "title": "Kontaktgruppe · sådan kommer du i gang",
      "geometry": {
        "x": 20,
        "y": 85,
        "width": 560,
        "height": 330,
        "rotation": 0,
        "z": 1
      },
      "content": {
        "text": "Denne skabelon bruger skolens Elevstamdata som udgangspunkt.\n\nDen opretter ikke egne elev-regneark, fordi du normalt allerede har elevdata i Plan eller kan importere dem fra skolens system.\n\nArbejdsgangen er:\n1. Importér Elevstamdata.\n2. Opret elevkortmatrix eller elevtavler fra datakilden.\n3. Skriv noter på den enkelte elev.\n4. Brug kalenderen til møder og opfølgning.\n5. Brug Skriv til udtalelser, når det er tid.",
        "fontSize": 18,
        "align": "left"
      },
      "settings": {
